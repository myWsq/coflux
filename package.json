{
  "name": "coflux",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev:server": "pnpm --filter @coflux/server dev",
    "dev:web": "pnpm --filter @coflux/web dev",
    "dev:mobile": "pnpm --filter @coflux/mobile dev",
    "dev:daemon": "cargo build -p coflux-supervisor -p coflux-worker && COFLUX_HOME=\"$PWD/.coflux-dev\" COFLUX_WORKER_CMD=\"$PWD/target/debug/coflux-worker\" ./target/debug/coflux-supervisor",
    "dev": "pnpm -r --parallel --filter @coflux/server --filter @coflux/web dev",
    "build": "pnpm -r build && cargo build --release",
    "build:daemon": "cargo build --release -p coflux-supervisor -p coflux-worker"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2"
  }
}
