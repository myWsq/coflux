{
  "name": "coflux",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev:server": "pnpm --filter @coflux/server dev",
    "dev:daemon": "pnpm --filter @coflux/daemon dev",
    "dev:web": "pnpm --filter @coflux/web dev",
    "dev": "pnpm -r --parallel --filter @coflux/server --filter @coflux/daemon --filter @coflux/web dev",
    "build": "pnpm -r build",
    "postinstall": "node scripts/fix-pty-perms.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
